
{
  "entities": {
    "Patient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Patient",
      "type": "object",
      "description": "A patient record aligned with FHIR Patient resource standards.",
      "properties": {
        "id": { "type": "string" },
        "active": { "type": "boolean", "default": true },
        "name": { "type": "string", "description": "Mapping to FHIR HumanName.text" },
        "gender": { "type": "string", "enum": ["male", "female", "other", "unknown"] },
        "birthDate": { "type": "string", "format": "date" },
        "telecom": { 
          "type": "object",
          "properties": {
            "system": { "type": "string", "default": "phone" },
            "value": { "type": "string" }
          }
        },
        "address": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "city": { "type": "string" },
            "district": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["Stable", "Urgent", "Follow-up"] },
        "registrationDate": { "type": "string", "format": "date-time" },
        "chwId": { "type": "string" }
      },
      "required": ["id", "name", "gender", "birthDate", "status"]
    },
    "Encounter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Encounter",
      "type": "object",
      "description": "A clinical assessment record aligned with FHIR Encounter resource standards.",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["planned", "arrived", "triaged", "in-progress", "finished", "cancelled"] },
        "subject": { "type": "string", "description": "Reference to Patient ID" },
        "period": {
          "type": "object",
          "properties": {
            "start": { "type": "string", "format": "date-time" },
            "end": { "type": "string", "format": "date-time" }
          }
        },
        "reasonCode": { "type": "array", "items": { "type": "string" }, "description": "Mapping to clinical red flags or seizure types" },
        "summary": { "type": "string" },
        "urgencyLevel": { "type": "string", "enum": ["EMERGENCY", "URGENT", "ROUTINE", "STABLE"] },
        "author": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "role": { "type": "string" }
          }
        },
        "discordanceNote": { "type": "string" }
      },
      "required": ["id", "status", "subject", "urgencyLevel"]
    },
    "HealthFacility": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HealthFacility",
      "type": "object",
      "description": "Registered health facility aligned with FHIR Organization resource standards.",
      "properties": {
        "id": { "type": "string" },
        "active": { "type": "boolean", "default": true },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["specialist", "district", "local"] },
        "telecom": { "type": "string" },
        "address": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "type"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/patients/{patientId}",
        "definition": {
          "entityName": "Patient",
          "schema": { "$ref": "#/backend/entities/Patient" },
          "description": "FHIR-Aligned Patient collection."
        }
      },
      {
        "path": "/patients/{patientId}/encounters/{encounterId}",
        "definition": {
          "entityName": "Encounter",
          "schema": { "$ref": "#/backend/entities/Encounter" },
          "description": "FHIR-Aligned Encounter sub-collection."
        }
      }
    ]
  }
}
